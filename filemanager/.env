# ==============================================
# FILE MANAGER - Configurazione
# ==============================================

# Credenziali di accesso
APP_USER=admin
APP_PASSWORD=secret123

# Cartelle gestibili (percorsi assoluti, separati da virgola)
ALLOWED_FOLDERS=/var/www/html,/home/user/documents,/tmp/shared

# Estensioni considerate file di testo (senza punto, separate da virgola)
# Questi file possono essere editati con l'editor integrato.
# Tutti gli altri file sono trattati come binari (solo download).
TEXT_EXTENSIONS=txt,log,md,ini,cfg,conf,yml,yaml,json,xml,html,htm,css,scss,less,sass,js,ts,jsx,tsx,vue,svelte,php,py,rb,java,c,cpp,h,hpp,go,rs,swift,kt,scala,sh,bash,zsh,fish,sql,env,gitignore,htaccess,editorconfig,toml,lock,csv,svg,makefile,cmake,r,m,mm,pl,lua,ex,exs,erl,hs,clj,scss
